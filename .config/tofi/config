prompt-text = " "
terminal = xdg-terminal-exec
matching-algorithm = fuzzy
num-results = 0
drun-launch = true

# font
# font = /usr/share/fonts/JetBrainsMono/JetBrainsMonoNerdFontMono-Medium.ttf
font = /usr/share/fonts/Ubuntu/UbuntuNerdFont-Medium.ttf
font-size = 15

# style
anchor = top
horizontal = true
width = 100%
height = 35
min-input-width = 240
result-spacing = 30
padding-top = 3
padding-bottom = 5
padding-left = 5
padding-right = 0
outline-width = 0
border-width = 0
hint-font = false

# theme
placeholder-color=#45475A
text-color = #CDD6F4
background-color = #1E1E2E
selection-color = #F9E2AF
selection-background = #1E1E2E
