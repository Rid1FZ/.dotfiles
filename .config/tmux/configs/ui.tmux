set-option -g status-position "bottom"
set-option -g status-justify "left"
set-option -g status-style bg=#11111b,fg=#cdd6f4
set-option -g status-left "#[fg=#89b4fa]█#[fg=#cdd6f4] "
set-option -g status-right " #{?client_prefix,#[fg=#f5c2e7],#[fg=#f38ba8]}  #[fg=#89b4fa]█"
set-option -g window-status-style fg=#6c7086
set-option -g window-status-format " #W "
set-option -g window-status-current-style fg=#f5e0dc
set-option -g window-status-current-format " #W "
