set-option -g status-position "bottom"
set-option -g status-justify "left"
set-option -g status-style bg=#181825,fg=#cdd6f4
set-option -g status-left "#{?client_prefix,#[fg=#89b4fa],#[fg=#fab387]}█"
set-option -g status-right "#{?client_prefix,#[fg=#89b4fa],#[fg=#fab387]}  █"
set-option -g window-status-format "#[fg=#6c7086] #I:#W "
set-option -g window-status-current-format "#[fg=#fab387] #I:#W "

