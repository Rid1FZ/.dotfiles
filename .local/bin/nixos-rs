#!/usr/bin/env python3

import argparse
import os
import os.path
import shlex
import subprocess
import sys


def _run_cmd(cmd: str) -> int:
    return subprocess.run(shlex.split(cmd)).returncode


def update_flakes(flakes_dir: str) -> int:
    return _run_cmd(f"sudo nix flake update --flake {flakes_dir}")


def rebuild(flakes_dir: str, hostname: str) -> int:
    return _run_cmd(f"sudo nixos-rebuild switch --flake {flakes_dir}#{hostname}")


def main() -> int:
    flakes_dir = (
        os.environ.get("DOTFILES", os.path.expanduser("~/Projects/dotfiles")) + "/nixos"
    )

    parser = argparse.ArgumentParser(
        prog="nixos-rs",
        description="Rebuild nixos and switch to newly built generation",
    )

    parser.add_argument(
        "--flake",
        action="store",
        type=str,
        default=flakes_dir,
        help="flakes directory",
    )

    parser.add_argument(
        "--update",
        action="store_true",
        help="update the flakes before rebuilding",
    )

    arguments = parser.parse_args()

    if not os.path.isfile("/etc/NIXOS"):
        parser.error("not running on nixos")

    flakes_dir = arguments.flake
    if not os.path.exists(flakes_dir):
        parser.error(
            "dotfiles directory does not exists or DOTFILES environment variable not set"
        )

    if arguments.update and update_flakes(flakes_dir) != 0:
        parser.error("failed to update the flakes")

    return rebuild(flakes_dir, os.uname().nodename)


if __name__ == "__main__":
    sys.exit(main())
