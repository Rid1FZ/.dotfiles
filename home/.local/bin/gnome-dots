#!/usr/bin/env python3

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

DCONF_RELATIVE_PATH = "gnome.dconf"


class GnomeConfigError(Exception):
    """Custom exception for GNOME config operations."""


def eprint(msg: str) -> None:
    print(f"Error: {msg}", file=sys.stderr)


def check_dconf_exists() -> None:
    """
    Ensure the `dconf` executable exists in PATH.
    """
    if shutil.which("dconf") is None:
        raise GnomeConfigError("`dconf` command not found. ")


def get_dotfiles_path() -> Path:
    dotfiles = os.environ.get("DOTFILES", "~/Projects/dotfiles")

    path = Path(dotfiles).expanduser().resolve()

    if not path.exists():
        raise GnomeConfigError(f"$DOTFILES path does not exist: {path}")

    if not path.is_dir():
        raise GnomeConfigError(f"$DOTFILES is not a directory: {path}")

    return path


def get_dconf_file() -> Path:
    dotfiles_path = get_dotfiles_path()
    return dotfiles_path / DCONF_RELATIVE_PATH


def dump_gnome_config() -> None:
    check_dconf_exists()

    dconf_file = get_dconf_file()

    # Ensure parent directory exists
    dconf_file.parent.mkdir(parents=True, exist_ok=True)

    try:
        result = subprocess.run(
            ["dconf", "dump", "/"],
            capture_output=True,
            text=True,
            check=True,
        )

        # Avoid writing empty dumps
        if not result.stdout.strip():
            raise GnomeConfigError("dconf dump returned empty output.")

        with open(dconf_file, "w", encoding="utf-8") as f:
            f.write(result.stdout)

    except subprocess.CalledProcessError as e:
        raise GnomeConfigError(f"Failed to dump GNOME config:\n{e.stderr.strip()}") from e

    print(f"GNOME config written to: {dconf_file}")


def load_gnome_config() -> None:
    check_dconf_exists()

    dconf_file = get_dconf_file()

    if not dconf_file.exists():
        raise GnomeConfigError(f"Config file does not exist: {dconf_file}")

    if not dconf_file.is_file():
        raise GnomeConfigError(f"Not a regular file: {dconf_file}")

    try:
        with open(dconf_file, "r", encoding="utf-8") as f:
            content = f.read()

        if not content.strip():
            raise GnomeConfigError("Config file is empty.")

        subprocess.run(
            ["dconf", "load", "/"],
            input=content,
            text=True,
            check=True,
        )

    except subprocess.CalledProcessError as e:
        raise GnomeConfigError(f"Failed to load GNOME config:\n{e.stderr.strip()}") from e

    print(f"GNOME config loaded from: {dconf_file}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Backup and restore GNOME dconf configuration.")

    subparsers = parser.add_subparsers(
        dest="command",
        required=True,
        help="Available subcommands",
    )

    subparsers.add_parser(
        "write",
        help="Write current GNOME config to $DOTFILES/gnome.dconf",
    )

    subparsers.add_parser(
        "load",
        help="Load GNOME config from $DOTFILES/gnome.dconf",
    )

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    try:
        match args.command:
            case "write":
                dump_gnome_config()

            case "load":
                load_gnome_config()

            case _:
                parser.error(f"Unknown command: {args.command}")

    except KeyboardInterrupt:
        parser.error("Operation cancelled by user.")

    except GnomeConfigError as e:
        parser.error(str(e))


if __name__ == "__main__":
    main()
