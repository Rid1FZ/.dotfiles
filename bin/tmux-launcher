#!/bin/env python3

import subprocess
import shlex
import os
import shutil


def main():
    # if tmux is already running or not installed, just skip
    if os.environ.get("TMUX") or not shutil.which("tmux"):
        return

    output = (
        subprocess.run(
            shlex.split("tmux ls -F '#{session_id}:#{?session_attached,1,0}'"),
            capture_output=True,
        )
        .stdout.decode()
        .splitlines(keepends=False)
    )

    for session in output:
        session_id, attached = session.split(":")
        if attached == "0":
            subprocess.run(shlex.split(f"tmux attach -t {session_id}"))
            return

    subprocess.run(shlex.split("tmux new"))


if __name__ == "__main__":
    main()
